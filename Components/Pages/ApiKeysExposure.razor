@page "/vulnerabilities/api-keys-exposure"
@rendermode InteractiveServer
@using DotnetSecurityFailures.Services
@inject IJSRuntime JSRuntime
@inject VulnerabilityService VulnerabilityService

<PageTitle>API Keys Exposure - .NET Security</PageTitle>

<VulnerabilityLayout Slug="api-keys-exposure" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <h6>API Key Exposure Demo:</h6>
        <p class="small text-muted">
            Call backend API and inspect how the API key is exposed in the response
        </p>

        <div class="mb-3">
            <label class="form-label">Service to Call:</label>
            <select class="form-select" @bind="selectedService">
                <option value="stripe">Stripe Payment</option>
                <option value="aws">AWS Services</option>
                <option value="sendgrid">SendGrid Email</option>
            </select>
        </div>

        <button class="btn btn-primary w-100" @onclick="CallAPI">
            Call API
        </button>

        @if (!string.IsNullOrEmpty(responseData))
        {
            <div class="@responseCssClass mt-3">
                <strong>@responseTitle</strong>
                <pre class="mb-0 mt-2" style="white-space: pre-wrap;">@responseData</pre>
            </div>
        }

        <div class="alert alert-info mt-3">
            <strong>How to Verify Exposure (F12 DevTools):</strong>
            <ol class="mb-0 mt-2">
                <li>Press <strong>F12</strong> to open DevTools</li>
                <li>Go to <strong>Network</strong> tab</li>
                <li>Click "Call API" button above</li>
                <li>Find the request to <code>initialize</code></li>
                <li>View the <strong>Response</strong> tab - API key is exposed!</li>
                <li>Check <strong>Console</strong> tab - key is also logged there</li>
            </ol>
        </div>
    </DemoContent>

    <ExplanationContent>
        <p>
            The application exposes API keys by sending them to the client. 
            Once an API key reaches the browser, it can be extracted from multiple sources and abused.
        </p>

        <h6 class="mt-3">How API keys get exposed:</h6>
        <ul>
            <li><strong>Network Responses:</strong> Keys sent in JSON responses visible in DevTools</li>
            <li><strong>JavaScript Variables:</strong> Keys embedded in client-side code</li>
            <li><strong>Browser Console:</strong> Keys logged during debugging</li>
            <li><strong>Local Storage:</strong> Keys stored in browser storage</li>
            <li><strong>Source Code:</strong> Keys hardcoded in HTML/JS files</li>
        </ul>

        <h6 class="mt-3">Real-world consequences:</h6>
        <ul>
            <li>Financial loss from unauthorized API usage</li>
            <li>Data breaches through compromised cloud resources</li>
            <li>Service abuse (spam, DDoS via your account)</li>
            <li>Rate limit exhaustion blocking legitimate users</li>
            <li>Complete account takeover</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against API Key Exposure:</h5>
        <ol>
            <li>
                <strong>Never Send Keys to Client</strong>
                <ul>
                    <li>Keep all secrets server-side only</li>
                    <li>Use Backend-for-Frontend (BFF) pattern</li>
                    <li>Proxy all external API calls through your backend</li>
                </ul>
            </li>
            <li>
                <strong>Public vs Private Keys</strong>
                <ul>
                    <li>Only publishable keys in client (e.g., Stripe pk_)</li>
                    <li>All secret keys server-side only (e.g., Stripe sk_)</li>
                    <li>Understand which keys are safe for client-side</li>
                </ul>
            </li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// Keep API keys server-side only

// All requests that require secret API keys should be made from the server-side
[HttpPost("/api/weather/data")]
[Authorize]
public async Task<IActionResult> GetWeatherData(
    [FromBody] WeatherRequest request)
{
    // API key retrieved from secure storage
    var apiKey = await _secretClient.GetSecretAsync(
        "WeatherApiKey");
    
    // Backend calls external API
    var weatherData = await _weatherClient.GetDataAsync(
        apiKey.Value, 
        request.Location);
    
    // Only data returned to client, not the key
    return Ok(weatherData);
}
""";
    private const string VulnerableCode = """
// DANGEROUS: Exposing API keys to client

// Backend sends key to frontend
[HttpPost("/api/vulnerabilities/api-keys-exposure/initialize")]
public IActionResult Initialize([FromBody] InitRequest request)
{
    var apiKey = GetApiKeyForService(request.Service);
    
    // VULNERABILITY: Returning secret key to client
    return Ok(new
    {
        apiKey = apiKey,  // Exposed in network response!
        service = request.Service,
        message = "Service initialized with API key"
    });
}


// Even worse: Hardcoded in JavaScript on the client
// const API_KEY = 'sk_live_51H8xYz2eZvKYlo2C9fXqhT8vWx';
// const STRIPE_KEY = 'pk_live_51H8xYz2eZvKYlo2CkjhEqQkV4';

// Or in mobile app configuration
public class AppConfig
{
    public const string AwsAccessKey = "AKIAIOSFODNN7EXAMPLE";
    public const string AwsSecretKey = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY";
}
""";

    private string selectedService = "stripe";
    private string responseData = "";
    private string responseTitle = "";
    private string responseCssClass = "";

    protected override void OnInitialized()
    {
        var vulnerability = VulnerabilityService.GetBySlug("api-keys-exposure")
            ?? throw new InvalidOperationException($"Vulnerability not found: api-keys-exposure");
    }

    private async Task CallAPI()
    {
        responseData = "";
        responseTitle = "";

        // Call API via JavaScript fetch to make it visible in DevTools Network tab
        var result = await JSRuntime.InvokeAsync<string>(
            "callVulnerableApiKey", 
            selectedService);

        if (!string.IsNullOrEmpty(result))
        {
            responseCssClass = "alert alert-danger";
            responseTitle = "VULNERABILITY - API KEY EXPOSED!";
            responseData = result;
        }
        else
        {
            responseCssClass = "alert alert-warning";
            responseTitle = "Error";
            responseData = "Failed to call API";
        }
    }
}

<script>
    window.callVulnerableApiKey = async function(service) {
        try {
            const response = await fetch('/api/vulnerabilities/api-keys-exposure/initialize', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': '' // Empty to avoid antiforgery for demo
                },
                body: JSON.stringify({ service: service })
            });

            const result = await response.json();

            // VULNERABILITY: Log the exposed API key to console
            console.log('%c[VULNERABILITY] API Key Exposed!', 'color: red; font-weight: bold; font-size: 16px');
            console.log('Service:', result.service);
            console.log('API Key:', result.apiKey);
            console.log('Full Response:', result);

            return `Service: ${result.service}
API Key: ${result.apiKey}
Message: ${result.message}

This API key is now visible in:
- Network tab (Response)
- Console logs (above)
- JavaScript memory
- Browser cache

An attacker could:
1. Extract it from DevTools
2. Use it for unauthorized access
3. Cause financial damage
4. Exhaust API quotas`;
        } catch (error) {
            console.error('Error calling API:', error);
            return null;
        }
    }
</script>
