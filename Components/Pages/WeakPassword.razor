@page "/vulnerabilities/weak-password"
@rendermode InteractiveServer
@using DotnetSecurityFailures.Models
@using DotnetSecurityFailures.Services
@inject VulnerabilityService VulnerabilityService

<PageTitle>Weak Password - .NET Security</PageTitle>

<VulnerabilityLayout Slug="weak-password" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <h6>Vulnerable Registration Form:</h6>
        
        <div class="mb-3">
            <label class="form-label">Username:</label>
            <input type="text" class="form-control" @bind="username" placeholder="john_doe" />
        </div>
        
        <div class="mb-3">
            <label class="form-label">Password:</label>
            <input type="password" class="form-control" @bind="password" placeholder="Enter password" />
            <small class="text-muted">Minimum 3 characters - DANGEROUSLY WEAK!</small>
        </div>
        
        <button class="btn btn-primary" @onclick="Register">Register</button>

        @if (!string.IsNullOrEmpty(registrationResult))
        {
            <div class="alert @(registrationSuccess ? "alert-danger" : "alert-secondary") mt-3">
                <strong>Registration Result:</strong>
                <pre class="mb-0 mt-2" style="white-space: pre-wrap;">@registrationResult</pre>
            </div>
        }

        <div class="alert alert-dark mt-3">
            <strong>Try these weak passwords:</strong>
            <ul class="mb-0">
                @foreach (var attack in vulnerability.PredefinedAttacks)
                {
                    <li>
                        <code style="cursor: pointer;" @onclick="() => SetPassword(attack.GetInputAsString())">
                            @attack.Input
                        </code>
                        @attack.Label
                    </li>
                }
            </ul>
        </div>
    </DemoContent>

    <ExplanationContent>
        <p>
            Weak password requirements allow users to create easily guessable passwords, making
            accounts vulnerable to brute-force attacks, dictionary attacks, and credential stuffing.
            Common issues include short minimum length, no complexity requirements, and acceptance
            of common passwords.
        </p>
        
       
        <h6 class="mt-4">Real-world consequences:</h6>
        <ul>
            <li><strong>Account takeover</strong> - attackers easily guess or brute-force passwords</li>
            <li><strong>Credential stuffing</strong> - reused passwords from breaches work across sites</li>
            <li><strong>Dictionary attacks</strong> - common words are cracked in seconds</li>
            <li><strong>Mass compromise</strong> - many accounts use same weak passwords</li>
            <li><strong>Brute-force attacks</strong> - short passwords have small keyspace</li>
            <li><strong>Data breaches</strong> - compromised accounts lead to data theft</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against Weak Passwords:</h5>
        <ol>
            <li>
                <strong>Minimum length 12+ characters</strong> - NIST 800-63B recommends at least 
                8 characters, but 12+ provides better security margin
            </li>
            <li>
                <strong>Complexity requirements</strong> - require mix of uppercase, lowercase, 
                digits, and special characters to increase keyspace
            </li>
            <li>
                <strong>Block common passwords</strong> - check against top 10,000 most common 
                passwords list (available from SecLists, OWASP, etc.)
            </li>
            <li>
                <strong>Check breached passwords</strong> - use Have I Been Pwned API (k-anonymity model) 
                to reject passwords found in data breaches
            </li>
            <li>
                <strong>Password strength meter</strong> - provide real-time visual feedback 
                using libraries like zxcvbn
            </li>
            <li>
                <strong>Multi-factor authentication</strong> - require second factor (TOTP, WebAuthn, 
                SMS) as defense in depth
            </li>
            <li>
                <strong>Rate limiting</strong> - limit failed login attempts to prevent brute-force 
                attacks (e.g., AspNetCoreRateLimit library)
            </li>
            <li>
                <strong>Passkeys/WebAuthn</strong> - consider passwordless authentication as 
                modern alternative to passwords
            </li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// Strong password requirements with modern validation
using Microsoft.AspNetCore.Identity;

// ASP.NET Identity with STRONG configuration
services.Configure<IdentityOptions>(options =>
{
    // NIST 800-63B compliant settings
    options.Password.RequireDigit = true;
    options.Password.RequiredLength = 12;  // Minimum 12 chars
    options.Password.RequireNonAlphanumeric = true;
    options.Password.RequireUppercase = true;
    options.Password.RequireLowercase = true;
    options.Password.RequiredUniqueChars = 4;
});

// Custom validator for breached passwords
public class BreachedPasswordValidator<TUser> 
    : IPasswordValidator<TUser> where TUser : class
{
    private readonly HttpClient _httpClient;
    
    public async Task<IdentityResult> ValidateAsync(
        UserManager<TUser> manager,
        TUser user,
        string password)
    {
        // Check against Have I Been Pwned API
        var sha1 = SHA1.HashData(Encoding.UTF8.GetBytes(password));
        var hashString = Convert.ToHexString(sha1);
        var prefix = hashString[..5];
        
        var response = await _httpClient
            .GetStringAsync($"https://api.pwnedpasswords.com/range/{prefix}");
        
        if (response.Contains(hashString[5..]))
        {
            return IdentityResult.Failed(
                new IdentityError 
                { 
                    Description = "Password found in breach database"
                });
        }
        
        // Check against common passwords list
        var commonPasswords = LoadCommonPasswords();
        if (commonPasswords.Contains(password.ToLower()))
        {
            return IdentityResult.Failed(
                new IdentityError 
                { 
                    Description = "Password is too common"
                });
        }
        
        return IdentityResult.Success;
    }
}

// Register the validator
services.AddScoped<IPasswordValidator<ApplicationUser>,
    BreachedPasswordValidator<ApplicationUser>>();
""";
    private const string VulnerableCode = """
// Minimal password requirements
public class RegisterModel
{
    [Required]
    [MinLength(3)]  // Too short!
    public string Password { get; set; }
}

public IActionResult Register(RegisterModel model)
{
    if (ModelState.IsValid)
    {
        // DANGER: No complexity checks!
        // No common password check!
        // No breach database check!
        var user = new User
        {
            Username = model.Username,
            PasswordHash = HashPassword(model.Password)
        };
        
        db.Users.Add(user);
        db.SaveChanges();
        
        return Ok("Account created");
    }
    
    return BadRequest();
}

// ASP.NET Identity with WEAK settings
services.Configure<IdentityOptions>(options =>
{
    options.Password.RequireDigit = false;
    options.Password.RequiredLength = 4;
    options.Password.RequireNonAlphanumeric = false;
    options.Password.RequireUppercase = false;
    options.Password.RequireLowercase = false;
});
""";

    private Vulnerability? vulnerability;

    private string username = "";
    private string password = "";
    private string? registrationResult;
    private bool registrationSuccess = false;

    protected override void OnInitialized()
    {
        vulnerability = VulnerabilityService.GetBySlug("weak-password")
            ?? throw new InvalidOperationException($"Vulnerability not found: weak-password");
    }

    private void Register()
    {
        ClearResults();

        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            registrationResult = "Please fill in all fields";
            return;
        }

        // VULNERABLE: Minimal validation (minimum 3 characters only)
        if (password.Length < 3)
        {
            registrationResult = "Password must be at least 3 characters";
            return;
        }

        // Check if password matches a known weak pattern
        var predefinedAttack = vulnerability!.PredefinedAttacks
            .FirstOrDefault(a => a.GetInputAsString().Equals(password, StringComparison.OrdinalIgnoreCase));

        if (predefinedAttack != null)
        {
            registrationSuccess = true;
            registrationResult = predefinedAttack.Description;
        }
        else if (password.Length < 8)
        {
            registrationSuccess = true;
            registrationResult = $"VULNERABILITY EXPLOITED!\n\n" +
                               $"Short password accepted!\n" +
                               $"Password length: {password.Length} characters\n" +
                               $"Can be brute-forced quickly\n\n" +
                               $"Attack estimate:\n" +
                               $"  - Possible combinations: ~62^{password.Length}\n" +
                               $"  - Time to crack: Minutes to hours\n" +
                               $"  - Attack type: Brute-force\n\n" +
                               $"Account vulnerable to brute-force attack!";
        }
        else
        {
            registrationSuccess = true;
            registrationResult = $"Account created for: {username}\n\n" +
                               $"WARNING: Password accepted despite weak requirements!\n" +
                               $"No checks for:\n" +
                               $"  - Common passwords\n" +
                               $"  - Breached passwords\n" +
                               $"  - Complexity requirements\n" +
                               $"  - Character diversity\n\n" +
                               $"Account may still be vulnerable!";
        }
    }

    private void SetPassword(string pwd)
    {
        password = pwd;
        ClearResults();
    }

    private void ClearResults()
    {
        registrationResult = null;
        registrationSuccess = false;
    }
}
