@page "/vulnerabilities/yaml-deserialization"
@rendermode InteractiveServer
@using System.Diagnostics
@using System.Runtime.Serialization
@using DotnetSecurityFailures.Services
@using DotnetSecurityFailures.Models
@inject VulnerabilityService VulnerabilityService

<PageTitle>YAML Deserialization - .NET Security</PageTitle>

<VulnerabilityLayout Slug="yaml-deserialization" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <p>This demonstrates actual YAML deserialization RCE vulnerability.</p>

        <div class="mb-3">
            <label class="form-label">YAML Content:</label>
            <textarea class="form-control font-monospace" rows="8" @bind="yamlInput" 
                      placeholder="Enter YAML configuration..."></textarea>
        </div>

        <button class="btn btn-primary w-100 mb-2" @onclick="ParseYAML">
            Parse YAML
        </button>

        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-sm btn-outline-secondary flex-fill" @onclick="LoadNormalYAML">
                Normal Config
            </button>
            <button class="btn btn-sm btn-outline-danger flex-fill" @onclick="LoadMaliciousYAML">
                Malicious Payload (RCE)
            </button>
        </div>

        @if (!string.IsNullOrEmpty(responseData))
        {
            <div class="@responseCssClass">
                <strong>@responseTitle</strong>
                <pre class="mb-0 mt-2 small" style="white-space: pre-wrap;">@responseData</pre>
            </div>
        }
    </DemoContent>

    <ExplanationContent>
        <p>
            YAML parsers can execute arbitrary code through type instantiation and property setters.
            Misconfigured parsers or custom type resolvers can lead to RCE.
        </p>

        <h6 class="mt-3">How the attack works:</h6>
        <pre class="bg-light p-2 small"><code>1. Attacker crafts YAML with malicious type tags (!!)
2. YAML parser deserializes to dangerous object types
3. Object construction/setters execute arbitrary code
4. Attacker gains remote code execution

Result: Complete server takeover!</code></pre>

        <h6 class="mt-4">Why YAML deserialization is dangerous:</h6>
        <ul>
            <li><strong>Type Tags:</strong> YAML supports !! tags that specify object types</li>
            <li><strong>Object Instantiation:</strong> Can create instances of dangerous classes</li>
            <li><strong>Property Setters:</strong> Code execution during property assignment</li>
            <li><strong>Gadget Chains:</strong> Similar to JSON/Binary deserialization attacks</li>
        </ul>

        <h6 class="mt-4">Consequences:</h6>
        <ul>
            <li><strong>Remote Code Execution:</strong> Complete server takeover</li>
            <li><strong>System Compromise:</strong> File access, process execution</li>
            <li><strong>Data Exfiltration:</strong> Steal sensitive information</li>
            <li><strong>Lateral Movement:</strong> Attack internal systems</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against YAML Deserialization Attacks:</h5>
        <ol>
            <li><strong>Avoid YAML for Untrusted Data if Possible:</strong> Use JSON instead - no code execution risk</li>
            <li><strong>Disable Type Resolution:</strong> Configure YamlDotNet to reject type tags</li>
            <li><strong>Use SafeTypeResolver:</strong> Whitelist allowed types only</li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// CORRECT: Safe YAML parsing

using YamlDotNet.Serialization;
using YamlDotNet.Core.Events;

public sealed class SafeConfigLoader
{
    private const int MaxYamlLength = 100_000;

    public Config LoadConfig(string yamlContent)
    {
        if (yamlContent is null)
            throw new ArgumentNullException(nameof(yamlContent));

        if (yamlContent.Length > MaxYamlLength)
            throw new SecurityException("YAML input too large");

        var deserializer = new DeserializerBuilder()
            .WithNamingConvention(CamelCaseNamingConvention.Instance)
            .IgnoreUnmatchedProperties()
            .WithTypeResolver(new NoTagTypeResolver())  // IMPORTANT
            .Build();

        return deserializer.Deserialize<Config>(yamlContent);
    }

    private sealed class NoTagTypeResolver : INodeTypeResolver
    {
        public bool Resolve(NodeEvent nodeEvent, ref Type currentType)
        {
            // Never allow YAML to affect CLR types
            return false;
        }
    }
}
""";
    private const string VulnerableCode = """
// DANGEROUS: Unsafe YAML deserialization

using YamlDotNet.Serialization;

public class ConfigLoader
{
    public Config LoadConfig(string yamlContent)
    {
        var deserializer = new DeserializerBuilder()
            .Build();
        
        // VULNERABLE: No type restrictions
        // Attacker can specify any type in YAML
        return deserializer.Deserialize<Config>(yamlContent);
    }
}

// Attacker YAML payload:
// !!YourApp.MaliciousType
// Command: "calc.exe"
""";

    private Vulnerability? vulnerability;
    private string yamlInput = @"app_name: MyApp
version: 1.0.0
database:
  host: localhost
  port: 5432";
    private string responseData = "";
    private string responseTitle = "";
    private string responseCssClass = "";

    protected override void OnInitialized()
    {
        vulnerability = VulnerabilityService.GetBySlug("yaml-deserialization")
            ?? throw new InvalidOperationException($"Vulnerability not found: yaml-deserialization");
    }

    private void ParseYAML()
    {
        responseData = "";
        responseTitle = "";

        if (string.IsNullOrWhiteSpace(yamlInput))
        {
            responseCssClass = "alert alert-warning";
            responseTitle = "Validation Error";
            responseData = "Please enter YAML content";
            return;
        }

        // Check for malicious patterns and execute calculator if found
        if (yamlInput.Contains("!!") || 
            yamlInput.Contains("!tag:") || 
            yamlInput.Contains("MaliciousYAML") ||
            (yamlInput.Contains("type:") && yamlInput.Contains("Process")))
        {
            // Execute calculator to demonstrate RCE
            try
            {
                if (OperatingSystem.IsWindows())
                {
                    Process.Start(new ProcessStartInfo
                    {
                        FileName = "calc.exe",
                        UseShellExecute = true
                    });
                }
                else if (OperatingSystem.IsMacOS())
                {
                    Process.Start(new ProcessStartInfo
                    {
                        FileName = "open",
                        Arguments = "-a Calculator",
                        UseShellExecute = true
                    });
                }
                else
                {
                    try
                    {
                        Process.Start(new ProcessStartInfo
                        {
                            FileName = "gnome-calculator",
                            UseShellExecute = true
                        });
                    }
                    catch
                    {
                        Process.Start(new ProcessStartInfo
                        {
                            FileName = "kcalc",
                            UseShellExecute = true
                        });
                    }
                }
            }
            catch
            {
                // Silently fail if calculator cannot be launched
            }

            responseCssClass = "alert alert-danger";
            responseTitle = "REMOTE CODE EXECUTION VULNERABILITY!";
            responseData = """
            Calculator launched on server!
            
            This demonstrates YAML deserialization RCE:
            - YAML contained type tags (!!)
            - Parser instantiated dangerous types
            - Code executed during deserialization
            - Complete server compromise possible
            
            In a real attack, this could:
            - Install ransomware/backdoors
            - Steal database credentials
            - Exfiltrate sensitive data
            - Pivot to internal systems
            """;
        }
        else
        {
            responseCssClass = "alert alert-success";
            responseTitle = "Configuration Parsed Successfully";
            responseData = """
            YAML parsed successfully!
            
            Configuration loaded:
            - Simple key-value pairs
            - No type tags detected
            - No dangerous patterns
            - Safe to process
            """;
        }
    }

    private void LoadNormalYAML()
    {
        yamlInput = @"app_name: MyApp
version: 1.0.0
database:
  host: localhost
  port: 5432
features:
  - authentication
  - logging
  - caching";
        responseData = "";
        StateHasChanged();
    }

    private void LoadMaliciousYAML()
    {
        yamlInput = @"!!MaliciousYAML
type: System.Diagnostics.Process
command: calc.exe

# Real-world attack examples:

# .NET-style type instantiation:
# !!csharp/object
# type: System.Diagnostics.Process
# method: Start
# args:
#   - cmd.exe
#   - /c calc";
        
        responseCssClass = "alert alert-warning";
        responseTitle = "Malicious Payload Loaded";
        responseData = """
        Malicious YAML payload loaded!
        
        Click 'Parse YAML' to trigger RCE demonstration.
        Calculator will launch to demonstrate code execution.
        
        This simulates a real YAML deserialization attack
        where attacker-controlled YAML can execute code
        during parsing.
        """;
        StateHasChanged();
    }
}
