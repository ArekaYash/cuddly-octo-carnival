@page "/vulnerabilities/stored-xss"
@rendermode InteractiveServer
@using DotnetSecurityFailures.Models
@using DotnetSecurityFailures.Services
@inject VulnerabilityService VulnerabilityService

<PageTitle>Stored XSS - .NET Security</PageTitle>

<VulnerabilityLayout Slug="stored-xss" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <h6>Blog Comment System:</h6>
        
        <div class="mb-3">
            <label for="username" class="form-label">Name:</label>
            <input type="text" class="form-control" id="username" @bind="username" 
                   placeholder="Your name" />
        </div>
        <div class="mb-3">
            <label for="comment" class="form-label">Comment:</label>
            <textarea class="form-control" id="comment" @bind="commentText" 
                      rows="3" placeholder="Write your comment..."></textarea>
        </div>
        <button class="btn btn-primary" @onclick="PostComment">Post Comment</button>

        <hr class="my-4" />

        <h6>Comments (@comments.Count):</h6>
        @foreach (var comment in comments)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <strong>@comment.Username</strong>
                    <small class="text-muted">(@comment.Timestamp.ToString("HH:mm"))</small>
                    <div class="mt-2">
                        @* VULNERABLE - displaying stored content without sanitization *@
                        @((MarkupString)comment.Text)
                    </div>
                </div>
            </div>
        }

        <div class="alert alert-dark mt-3">
            <strong>Try these payloads:</strong>
            <ul class="mb-0">
                @foreach (var attack in vulnerability.PredefinedAttacks)
                {
                    <li>
                        <code style="cursor: pointer;" @onclick="() => SetComment(attack.GetInput2AsString(), attack.GetInputAsString())">
                            @attack.GetInputAsString()
                        </code>
                        @attack.Label
                    </li>
                }
            </ul>
        </div>
    </DemoContent>

    <ExplanationContent>
        <p>
            Stored XSS (also called Persistent XSS) is the most dangerous type of XSS. 
            The malicious script is stored in the database and executed every time any user 
            views the affected page. Unlike Reflected XSS, no victim interaction is needed.
        </p>
        
        <h6 class="mt-3">How the attack works:</h6>
        <pre class="bg-light p-2 small">
<code>1. Attacker posts comment: &lt;script&gt;alert('XSS')&lt;/script&gt;
2. Application stores it in database without sanitization
3. Victim views the page
4. Application renders stored comment
5. Script executes in victim's browser

Result: Every visitor gets compromised!</code>
</pre>

        <h6 class="mt-3">Attack Flow:</h6>
        <ol>
            <li>Attacker posts comment with malicious script</li>
            <li>Script is stored in database</li>
            <li>Every visitor to the page loads the comment</li>
            <li>Script executes in each visitor's browser</li>
            <li>Mass compromise of user sessions</li>
        </ol>
        
        <h6 class="mt-4">Real-world consequences:</h6>
        <ul>
            <li><strong>Mass session hijacking</strong> - affects all users viewing the page</li>
            <li><strong>Worm propagation</strong> - self-replicating attacks (like Samy worm on MySpace)</li>
            <li><strong>Persistent backdoors</strong> - long-term access to application</li>
            <li><strong>Data theft from all users</strong> - steal cookies, tokens, personal data</li>
            <li><strong>Website defacement</strong> - modify page content for all users</li>
            <li><strong>Keylogging</strong> - capture all keystrokes on the page</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against Stored XSS:</h5>
        <ol>
            <li><strong>Use HtmlSanitizer library</strong> - whitelist safe HTML tags only</li>
            <li><strong>Use Markdown</strong> - safer alternative to raw HTML for user formatting</li>
            <li><strong>Content Security Policy (CSP)</strong> - prevent inline scripts with headers</li>
            <li><strong>Input validation</strong> - reject obviously malicious patterns</li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// CORRECT: Sanitize before storing
using Ganss.Xss;

public class CommentService
{
    private readonly HtmlSanitizer _sanitizer;
    
    public CommentService()
    {
        _sanitizer = new HtmlSanitizer();
        
        // Allow only safe HTML tags
        _sanitizer.AllowedTags.Clear();
        _sanitizer.AllowedTags.Add("b");
        _sanitizer.AllowedTags.Add("i");
        _sanitizer.AllowedTags.Add("em");
        _sanitizer.AllowedTags.Add("strong");
        _sanitizer.AllowedTags.Add("p");
    }
    
    public void AddComment(string username, string text)
    {
        dbContext.Comments.Add(new Comment
        {
            Username = username,
            Text = _sanitizer.Sanitize(text)  // Sanitized!
        });
        dbContext.SaveChanges();
    }
}

// Display safely (Blazor auto-encodes by default)
@@foreach (var comment in comments)
{
    <div>@@comment.Text</div>
}

// Or use Markdown instead of HTML
using Markdig;
var html = Markdown.ToHtml(commentText);
var sanitized = _sanitizer.Sanitize(html);
""";
    private const string VulnerableCode = """
// DANGEROUS: Storing and displaying raw HTML
public class Comment
{
    public string Username { get; set; }
    public string Text { get; set; }
}

// Storing without sanitization
[HttpPost]
public IActionResult PostComment(string username, string text)
{
    dbContext.Comments.Add(new Comment
    {
        Username = username,
        Text = text  // Raw HTML stored!
    });
    dbContext.SaveChanges();
    return Ok();
}

// Displaying without encoding
@foreach (var comment in comments)
{
    <div>@((MarkupString)comment.Text)</div>
}

// Input: <script>alert('XSS')</script>
// Stored in DB as-is
// Rendered: <script>alert('XSS')</script>
// Result: Executes for every user!
""";

    private Vulnerability? vulnerability;

    private string username = "";
    private string commentText = "";
    private List<Comment> comments = new();

    protected override void OnInitialized()
    {
        vulnerability = VulnerabilityService.GetBySlug("stored-xss")
            ?? throw new InvalidOperationException($"Vulnerability not found: stored-xss");

        comments.Add(new Comment 
        { 
            Username = "Alice", 
            Text = "Great article! Very informative.",
            Timestamp = DateTime.Now.AddMinutes(-30)
        });
        comments.Add(new Comment 
        { 
            Username = "Bob", 
            Text = "Thanks for sharing this. <b>Very helpful!</b>",
            Timestamp = DateTime.Now.AddMinutes(-15)
        });
    }

    private void PostComment()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(commentText))
        {
            return;
        }

        comments.Add(new Comment 
        { 
            Username = username, 
            Text = commentText,
            Timestamp = DateTime.Now
        });

        var predefinedAttack = vulnerability.PredefinedAttacks
            .FirstOrDefault(a => a.GetInputAsString() == commentText);

        username = "";
        commentText = "";
    }

    private void SetComment(string user, string text)
    {
        username = user;
        commentText = text;
    }

    private class Comment
    {
        public string Username { get; set; } = "";
        public string Text { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
}
