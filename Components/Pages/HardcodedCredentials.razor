@page "/vulnerabilities/hardcoded-credentials"
@rendermode InteractiveServer
@using DotnetSecurityFailures.Services
@inject VulnerabilityService VulnerabilityService

<PageTitle>Hardcoded Credentials - .NET Security</PageTitle>

<VulnerabilityLayout Slug="hardcoded-credentials" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <h6>Admin Panel Login:</h6>
        <div class="mb-3">
            <label class="form-label">Username:</label>
            <input type="text" class="form-control" @bind="username" placeholder="admin" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password:</label>
            <input type="password" class="form-control" @bind="password" placeholder="Enter password" />
        </div>
        <button class="btn btn-primary" @onclick="TryLogin">Login</button>

        @if (loginMessage != null)
        {
            <div class="alert alert-@(loginSuccess ? "success" : "danger") mt-3" style="white-space: pre-wrap;">
                @loginMessage
            </div>
        }

        <div class="alert alert-dark mt-3">
            <strong>Try to find the credentials:</strong>
            <ul class="mb-0">
                <li><code style="cursor: pointer;" @onclick="@(() => SetCredentials("admin", "wrong"))">admin / wrong</code> - incorrect password</li>
                <li><code style="cursor: pointer;" @onclick="@(() => SetCredentials("admin", "SuperSecret123!"))">admin / SuperSecret123!</code> - hardcoded password from source</li>
                <li>Or inspect the page source code / use browser developer tools</li>
            </ul>
        </div>

        <div class="alert alert-warning mt-3">
            <strong>In Real Applications:</strong>
            <ul class="mb-0 small">
                <li>Attackers use <strong>ILSpy</strong> or <strong>dnSpy</strong> to decompile .NET DLLs</li>
                <li>Search GitHub/GitLab for leaked source code</li>
                <li>Check Git history for accidentally committed secrets</li>
                <li>Run <code>strings</code> command on binary files</li>
                <li>Inspect memory dumps of running processes</li>
            </ul>
        </div>
    </DemoContent>

    <ExplanationContent>
        <p>
            Hardcoded credentials are passwords, API keys, or secrets embedded directly in source code. 
            This is one of the most critical security vulnerabilities because credentials cannot be 
            changed without redeploying the application, and they're visible to anyone with access 
            to the code or compiled binaries.
        </p>
        
        <h6 class="mt-3">How attackers find hardcoded credentials:</h6>
        <pre class="bg-light p-2 small"><code>1. GitHub/GitLab Search:
   - Search: "password" "secret" "api_key" filename:*.cs
   - Look in public repositories

2. Decompilers for .NET:
   - ILSpy: Open DLL ? View ? Search for "password"
   - dnSpy: Full decompilation with debugging
   - dotPeek: JetBrains decompiler

3. Binary string extraction:
   - strings MyApp.dll | grep -i password
   - Find constants in compiled code

4. Git history:
   - git log -S "password" --all
   - Check deleted commits</code></pre>

        <h6 class="mt-4">Common places for hardcoded secrets:</h6>
        <ol>
            <li><strong>Constants:</strong> <code>private const string PASSWORD = "...";</code></li>
            <li><strong>Connection strings:</strong> <code>"Server=...;Password=admin123"</code></li>
            <li><strong>API keys:</strong> <code>var key = "sk_live_abc123...";</code></li>
            <li><strong>Encryption keys:</strong> <code>byte[] key = new byte[] { 0x01, ... };</code></li>
            <li><strong>Comments:</strong> <code>// TODO: password is Admin123!</code></li>
            <li><strong>Default credentials:</strong> Not changed from defaults</li>
        </ol>
        
        <h6 class="mt-4">Real-world consequences:</h6>
        <ul>
            <li><strong>Complete system compromise</strong> - full access to admin accounts</li>
            <li><strong>Impossible to rotate</strong> - changing requires code change and redeployment</li>
            <li><strong>All installations affected</strong> - one codebase = all deployments compromised</li>
            <li><strong>Compliance violations</strong> - PCI DSS, SOC 2, ISO 27001, HIPAA</li>
            <li><strong>Data breaches</strong> - access to databases, APIs, cloud services</li>
            <li><strong>Supply chain attacks</strong> - if code is shared/reused</li>
        </ul>

        <div class="alert alert-danger mt-3">
            <strong>Real Examples:</strong>
            <ul class="mb-0">
                <li><strong>Uber (2016)</strong> - AWS keys on GitHub, 57M records stolen</li>
                <li><strong>Toyota (2023)</strong> - 10 years of source code with keys leaked</li>
                <li><strong>Okta (2023)</strong> - hardcoded secret in source code</li>
                <li><strong>CircleCI (2023)</strong> - hardcoded secrets exposed 35K+ customers</li>
            </ul>
        </div>
    </ExplanationContent>    <PreventionContent>
        <h5>Proper Secret Storage:</h5>
        <ol>
            <li><strong>Azure Key Vault / AWS Secrets Manager</strong> - centralized secret management for production (recommended)</li>
            <li><strong>Environment Variables</strong> - set in hosting platform, never commit to code</li>
            <li><strong>User Secrets</strong> - built into .NET SDK for local development (dotnet user-secrets)</li>
            <li><strong>Never commit secrets to Git</strong> - use .gitignore for appsettings.Development.json and .env files</li>
            <li><strong>Hash passwords</strong> - never store plaintext, use BCrypt or Argon2</li>
            <li><strong>Rotate secrets regularly</strong> - change every 90 days, different per environment</li>
            <li><strong>Use secret scanners</strong> - git-secrets, truffleHog, GitGuardian to detect leaks</li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// CORRECT: Use configuration + secure storage

// appsettings.json (for non-sensitive config)
{
  "AdminCredentials": {
    "Username": "admin",
    "PasswordHash": "$2a$..."  // BCrypt hash
  }
}

// Read from configuration
public class AuthService
{
    private readonly IConfiguration _config;
    
    public AuthService(IConfiguration config)
    {
        _config = config;
    }
    
    public bool ValidateAdmin(string user, string pass)
    {
        string username = _config["AdminCredentials:Username"];
        string hash = _config["AdminCredentials:PasswordHash"];
        return user == username && BCrypt.Verify(pass, hash);
    }
}

// Environment Variables
string apiKey = Environment.GetEnvironmentVariable("SENDGRID_API_KEY")
    ?? throw new InvalidOperationException("API key not configured");

// Azure Key Vault
var client = new SecretClient(
    new Uri("https://myvault.vault.azure.net/"),
    new DefaultAzureCredential());
KeyVaultSecret secret = await client.GetSecretAsync("DbPassword");
string password = secret.Value;

// User Secrets (Development only)
// Right-click project -> Manage User Secrets
{
  "ConnectionStrings": {
    "DefaultConnection": "..."
  }
}

// AWS Secrets Manager
var awsClient = new AmazonSecretsManagerClient();
var request = new GetSecretValueRequest
{
    SecretId = "prod/db/password"
};
var response = await awsClient.GetSecretValueAsync(request);
""";
    private const string VulnerableCode = """
// DANGEROUS: Hardcoded admin credentials
public class AuthService
{
    // BAD: Credentials directly in code
    private const string ADMIN_USERNAME = "admin";
    private const string ADMIN_PASSWORD = "SuperSecret123!";
    
    public bool ValidateAdmin(string user, string pass)
    {
        return user == ADMIN_USERNAME && pass == ADMIN_PASSWORD;
    }
}

// Hardcoded database connection string
public class DatabaseService
{
    private string connString =
        "Server=prod-sql.company.com;" +
        "Database=MainDB;" +
        "User Id=sa;" +
        "Password=SqlP@ss123!;";
}

// Hardcoded API keys
public class EmailService
{
    private const string SENDGRID_KEY = "SG.abc123xyz789...";
    private const string STRIPE_KEY = "sk_live_51xyz789abc...";
    private const string AWS_SECRET = "wJalrXUtnFEMI/bPxRfiCYEXAMPLE";
}

// Hardcoded encryption keys
public class CryptoService
{
    private static readonly byte[] Key = new byte[]
    { 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08 };
}

// Even in comments - BAD!
// TODO: Change admin password from "Admin123!"
""";

    private string username = "";
    private string password = "";
    private string loginMessage;
    private bool loginSuccess;

    // VULNERABLE - Hardcoded credentials for demonstration
    private const string HARDCODED_ADMIN = "admin";
    private const string HARDCODED_PASSWORD = "SuperSecret123!";
    private const string HARDCODED_API_KEY = "sk_live_51abc123xyz";
    private const string HARDCODED_DB_PASSWORD = "SqlP@ss123!";

    protected override void OnInitialized()
    {
        var vulnerability = VulnerabilityService.GetBySlug("hardcoded-credentials")
            ?? throw new InvalidOperationException($"Vulnerability not found: hardcoded-credentials");
    }

    private void TryLogin()
    {
        loginSuccess = false;
        loginMessage = null;

        if (username == HARDCODED_ADMIN && password == HARDCODED_PASSWORD)
        {
            loginSuccess = true;
            loginMessage = "Successful login!\n\n" +
                          "But credentials were found in source code:\n\n" +
                          $"Username: {HARDCODED_ADMIN}\n" +
                          $"Password: {HARDCODED_PASSWORD}\n\n" +
                          "- In a real application, attacker could:\n" +
                          "- Decompile DLL using ILSpy or dnSpy\n" +
                          "- Find strings in compiled binary\n" +
                          "- View Git history for commits\n" +
                          "- Read leaked source code from GitHub\n\n" +
                          $"Also found in code:\n" +
                          $"- API key: {HARDCODED_API_KEY}\n" +
                          $"- DB password: {HARDCODED_DB_PASSWORD}";
        }
        else
        {
            loginMessage = "? Invalid credentials.\n\n" +
                          "Hint: Check the source code constants!\n" +
                          "In a real app: use ILSpy to decompile the DLL.";
        }
    }

    private void SetCredentials(string user, string pass)
    {
        username = user;
        password = pass;
        loginMessage = null;
        loginSuccess = false;
    }
}
