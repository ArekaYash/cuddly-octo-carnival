@page "/vulnerabilities/xml-bomb"
@rendermode InteractiveServer
@using System.Xml
@using System.Diagnostics
@using System.Text
@using DotnetSecurityFailures.Services
@using DotnetSecurityFailures.Models
@inject VulnerabilityService VulnerabilityService

<PageTitle>XML Bomb (Billion Laughs) - .NET Security</PageTitle>

<VulnerabilityLayout Slug="xml-bomb" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <div class="mb-3">
            <label class="form-label">XML Content:</label>
            <textarea class="form-control font-monospace" rows="8" @bind="xmlInput"
                      placeholder="Enter XML content..."></textarea>
        </div>

        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-sm btn-outline-secondary flex-fill" @onclick="LoadNormalXML">
                Normal XML
            </button>
            <button class="btn btn-sm btn-outline-danger flex-fill" @onclick="LoadBillionLaughs">
                Billion Laughs Attack
            </button>
        </div>

        <button class="btn btn-primary w-100 mb-2" @onclick="ParseXML" disabled="@isExecuting">
            @(isExecuting ? "Parsing..." : "Parse XML")
        </button>

        @if (!string.IsNullOrEmpty(responseData))
        {
            <div class="@responseCssClass">
                <strong>@responseTitle</strong>
                <pre class="mb-0 mt-2 small" style="white-space: pre-wrap;">@responseData</pre>
            </div>
        }
    </DemoContent>

    <ExplanationContent>
        <p>
            XML Bombs (Billion Laughs attack) exploit entity expansion in XML parsers to cause exponential memory growth,
            leading to Denial of Service. A small XML document can expand to gigabytes of data.
        </p>

        <h6 class="mt-3">How the attack works:</h6>
        <pre class="bg-light p-2 small"><code>1. Attacker defines nested XML entities in DTD
2. Each entity references multiple instances of previous entity
3. Final entity causes exponential expansion (e.g., 10^9 "lol" strings)
4. Parser consumes massive memory trying to expand entities
5. Server runs out of memory and crashes

Result: Complete Denial of Service!</code></pre>

        <h6 class="mt-4">Consequences:</h6>
        <ul>
            <li><strong>Denial of Service:</strong> Server runs out of memory and crashes</li>
            <li><strong>CPU Exhaustion:</strong> Parser spends excessive time expanding entities</li>
            <li><strong>Service Unavailable:</strong> Application becomes unresponsive</li>
            <li><strong>Cascading Failures:</strong> Can affect other applications on same server</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against XML Bombs:</h5>
        <ol>
            <li><strong>Disable DTD Processing:</strong> Set DtdProcessing = DtdProcessing.Prohibit</li>
            <li><strong>Limit Entity Expansion:</strong> Set MaxCharactersFromEntities to reasonable limit</li>
            <li><strong>Document Size Limits:</strong> Set MaxCharactersInDocument to prevent huge documents</li>
            <li><strong>Input Validation:</strong> Reject XML documents exceeding size threshold</li>
            <li><strong>Prefer JSON:</strong> JSON doesn't have entity expansion feature</li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// CORRECT: DTD processing disabled with strict limits
public string ProcessXML(string xmlContent)
{
    var settings = new XmlReaderSettings
    {
        DtdProcessing = DtdProcessing.Prohibit,  // SAFE!
        MaxCharactersFromEntities = 1024,
        MaxCharactersInDocument = 10_000_000,
        XmlResolver = null  // Disable external entities
    };

    using var reader = XmlReader.Create(
        new StringReader(xmlContent), settings);

    var doc = new XmlDocument();
    doc.Load(reader);

    return doc.OuterXml;
}
""";
    private const string VulnerableCode = """
// DANGEROUS: Explicitly enabling DTD processing
public string ProcessXML(string xmlContent)
{
    // VULNERABLE: Explicitly allowing DTD processing
    var settings = new XmlReaderSettings
    {
        DtdProcessing = DtdProcessing.Parse,  // DANGEROUS!
        MaxCharactersFromEntities = 0         // Unlimited expansion!
    };

    using var reader = XmlReader.Create(
        new StringReader(xmlContent), settings);

    var doc = new XmlDocument();
    doc.Load(reader);  // Can consume gigabytes of memory!

    return doc.OuterXml;
}
""";

    private Vulnerability? vulnerability;
    private string xmlInput = "";
    private string responseData = "";
    private string responseTitle = "";
    private string responseCssClass = "";
    private bool isExecuting = false;

    protected override void OnInitialized()
    {
        vulnerability = VulnerabilityService.GetBySlug("xml-bomb")
            ?? throw new InvalidOperationException($"Vulnerability not found: xml-bomb");
    }

    private async Task ParseXML()
    {
        responseData = "";
        responseTitle = "";

        if (string.IsNullOrWhiteSpace(xmlInput))
        {
            responseCssClass = "alert alert-warning";
            responseTitle = "Validation Error";
            responseData = "Please enter XML content";
            return;
        }

        isExecuting = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(100);

        try
        {
            var stopwatch = Stopwatch.StartNew();
            var initialMemory = GC.GetTotalMemory(false);

            var settings = new XmlReaderSettings
            {
                DtdProcessing = DtdProcessing.Parse,
                MaxCharactersFromEntities = 0
            };

            using var reader = XmlReader.Create(new StringReader(xmlInput), settings);
            var doc = new XmlDocument();
            doc.Load(reader);

            stopwatch.Stop();
            var finalMemory = GC.GetTotalMemory(false);
            var memoryUsed = finalMemory - initialMemory;

            // Analyze for entity expansion attack
            var entityCount = xmlInput.Split(new[] { "<!ENTITY" }, StringSplitOptions.None).Length - 1;
            var hasEntityReferences = xmlInput.Contains("&lol") || xmlInput.Contains("&a");
            var expandedLength = doc.OuterXml.Length;
            var compressionRatio = xmlInput.Length > 0 ? expandedLength / (double)xmlInput.Length : 1;

            if (entityCount > 5 && hasEntityReferences && compressionRatio > 10)
            {
                responseCssClass = "alert alert-danger";
                responseTitle = "XML BOMB DETECTED!";
                responseData = $"BILLION LAUGHS ATTACK SUCCESSFUL!\n\n" +
                               $"Attack Metrics:\n" +
                               $"- Entity Definitions: {entityCount}\n" +
                               $"- Input Size: {xmlInput.Length:N0} bytes\n" +
                               $"- Expanded Size: {expandedLength:N0} bytes\n" +
                               $"- Expansion Ratio: {compressionRatio:F1}x\n" +
                               $"- Memory Used: {memoryUsed:N0} bytes\n" +
                               $"- Parse Time: {stopwatch.ElapsedMilliseconds}ms\n\n" +
                               $"In a real attack with more entity levels:\n" +
                               $"- Could expand to gigabytes of data\n" +
                               $"- Would exhaust server memory\n" +
                               $"- Cause denial of service\n" +
                               $"- Crash the application";
            }
            else
            {
                responseCssClass = "alert alert-success";
                responseTitle = "XML Parsed Successfully";
                responseData = $"Document parsed without issues:\n\n" +
                               $"- Input Size: {xmlInput.Length:N0} bytes\n" +
                               $"- Output Size: {expandedLength:N0} bytes\n" +
                               $"- Parse Time: {stopwatch.ElapsedMilliseconds}ms\n" +
                               $"- Memory Used: {memoryUsed:N0} bytes\n\n" +
                               $"WARNING: This parser is still vulnerable!\n" +
                               $"DTD processing is enabled.\n" +
                               $"Always disable DTD or set strict limits.";
            }
        }
        finally
        {
            isExecuting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void LoadNormalXML()
    {
        xmlInput = """
<?xml version="1.0" encoding="UTF-8"?>
<root>
    <user>
        <name>John Doe</name>
        <email>john@example.com</email>
        <role>user</role>
    </user>
    <data>
        <item id="1">Normal XML content</item>
        <item id="2">No entity expansion</item>
    </data>
</root>
""";
        responseData = "";
        StateHasChanged();
    }

    private void LoadBillionLaughs()
    {
        xmlInput = """
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE lolz [
  <!ENTITY lol "lol">
  <!ENTITY lol2 "&lol;&lol;&lol;&lol;&lol;&lol;&lol;&lol;&lol;&lol;">
  <!ENTITY lol3 "&lol2;&lol2;&lol2;&lol2;&lol2;&lol2;&lol2;&lol2;&lol2;&lol2;">
  <!ENTITY lol4 "&lol3;&lol3;&lol3;&lol3;&lol3;&lol3;&lol3;&lol3;&lol3;&lol3;">
  <!ENTITY lol5 "&lol4;&lol4;&lol4;&lol4;&lol4;&lol4;&lol4;&lol4;&lol4;&lol4;">
  <!ENTITY lol6 "&lol5;&lol5;&lol5;&lol5;&lol5;&lol5;&lol5;&lol5;&lol5;&lol5;">
  <!ENTITY lol7 "&lol6;&lol6;&lol6;&lol6;&lol6;&lol6;&lol6;&lol6;&lol6;&lol6;">
  <!ENTITY lol8 "&lol7;&lol7;&lol7;&lol7;&lol7;&lol7;&lol7;&lol7;&lol7;&lol7;">
]> 
<lolz>&lol8;</lolz>
""";
        responseCssClass = "alert alert-warning";
        responseTitle = "Billion Laughs Attack Loaded";
        responseData = "XML Bomb payload loaded!\n\n" +
                       "Click 'Parse XML' to trigger the attack.\n\n" +
                       "This payload demonstrates entity expansion:\n" +
                       "- lol = 'lol' (3 bytes)\n" +
                       "- lol2 = 10 × lol = 30 bytes\n" +
                       "- lol3 = 10 × lol2 = 300 bytes\n" +
                       "- lol4 = 10 × lol3 = 3,000 bytes\n" +
                       "- lol5 = 10 × lol4 = 30,000 bytes\n" +
                       "- lol6 = 10 × lol5 = 300,000 bytes\n" +
                       "- lol7 = 10 × lol6 = 3,000,000 bytes\n" +
                       "- lol8 = 10 × lol7 = 30,000,000 bytes (30 MB!)\n\n" +
                       "Small input expands exponentially!\n" +
                       "This will consume significant memory and time.";
        StateHasChanged();
    }
}
