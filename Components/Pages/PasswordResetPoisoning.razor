@page "/vulnerabilities/password-reset-poisoning"
@rendermode InteractiveServer
@using DotnetSecurityFailures.Services
@using DotnetSecurityFailures.Models
@inject VulnerabilityService VulnerabilityService

<PageTitle>Password Reset Poisoning - .NET Security</PageTitle>

<VulnerabilityLayout Slug="password-reset-poisoning" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <h6>Simulate Password Reset Request:</h6>
        <p class="small text-muted">Test how application constructs reset links using Host header</p>

        <div class="mb-3">
            <label class="form-label">Email Address:</label>
            <input type="email" class="form-control" @bind="email" placeholder="victim@example.com" />
        </div>

        <div class="mb-3">
            <label class="form-label">Host Header (attacker controls):</label>
            <input type="text" class="form-control" @bind="hostHeader" placeholder="legitsite.com" />
            <small class="text-muted">In real attack, this comes from HTTP Host header</small>
        </div>

        <button class="btn btn-primary" @onclick="SendReset">
            Send Password Reset
        </button>

        @if (!string.IsNullOrEmpty(result))
        {
            <div class="@resultCssClass mt-3">
                <strong>Result:</strong>
                <pre class="mb-0 mt-2" style="white-space: pre-wrap;">@result</pre>
            </div>
        }

        @if (!string.IsNullOrEmpty(generatedEmail))
        {
            <div class="card mt-3 bg-light">
                <div class="card-header">
                    <strong>Generated Email (Sent to User)</strong>
                </div>
                <div class="card-body">
                    <pre class="mb-0" style="white-space: pre-wrap; font-size: 0.85em;">@generatedEmail</pre>
                </div>
            </div>
        }

        <div class="alert alert-dark mt-3">
            <strong>Try these attacks:</strong>
            <ul class="mb-0">
                @foreach (var attack in vulnerability.PredefinedAttacks)
                {
                    <li>
                        <code style="cursor: pointer;" @onclick="() => ExecuteAttack(attack)">
                            @attack.GetInputAsString()
                        </code>
                        @attack.Label
                    </li>
                }
            </ul>
        </div>
    </DemoContent>

    <ExplanationContent>
        <p>
            Password Reset Poisoning occurs when an application uses the HTTP Host header to construct password reset URLs.
            Attackers can manipulate this header to redirect reset tokens to their own domain.
        </p>

        <h6 class="mt-3">How the attack works:</h6>
        <pre class="bg-light p-2 small"><code>1. Attacker sends reset request with modified Host header:
   POST /api/auth/forgot-password HTTP/1.1
   Host: evil.com
   {"email":"victim@example.com"}

2. Application constructs URL using Host header:
   var resetUrl = $"https://{Request.Host}/reset?token=abc123";

3. Victim receives email with attacker's domain:
   Click here: https://evil.com/reset?token=abc123

4. Victim clicks link, token sent to attacker's domain

Result: Complete account takeover!</code></pre>

        <h6 class="mt-4">Consequences:</h6>
        <ul>
            <li><strong>Account takeover</strong> - attacker gains full access</li>
            <li><strong>Token theft</strong> - reset tokens redirected to attacker</li>
            <li><strong>Phishing amplification</strong> - legitimate system sends malicious links</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against Password Reset Poisoning:</h5>
        <ol>
            <li><strong>Never use Host header</strong> - don't use Request.Headers["Host"]</li>
            <li><strong>Configured base URL</strong> - store URL in appsettings.json</li>
            <li><strong>Host header validation</strong> - whitelist allowed hosts</li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// CORRECT: Using configured domain
[HttpPost("forgot-password")]
public async Task<IActionResult> ForgotPassword(
    string email, IConfiguration config)
{
    var user = await _userService.FindByEmailAsync(email);
    var token = await _userManager.GeneratePasswordResetTokenAsync(user);
    
    // SAFE: Use configured base URL
    var baseUrl = config[\"Application:BaseUrl\"];
    var resetUrl = $\"{baseUrl}/reset?token={token}\";
    
    await _emailService.SendEmailAsync(email, "Reset", resetUrl);
    return Ok();
}

// appsettings.json
{
  "Application": {
    "BaseUrl": "https://legitsite.com"
  }
}
""";
    private const string VulnerableCode = """
// DANGEROUS: Using Host header for reset link
[HttpPost("forgot-password")]
public async Task<IActionResult> ForgotPassword(string email)
{
    var user = await _userService.FindByEmailAsync(email);
    var token = await _userManager.GeneratePasswordResetTokenAsync(user);
    
    // VULNERABLE: Using Host header!
    var host = Request.Headers[\"Host\"].ToString();
    var resetUrl = $\"https://{host}/reset?token={token}\";
    
    await _emailService.SendEmailAsync(email, \"Reset\", resetUrl);
    return Ok();
}
""";

    private Vulnerability? vulnerability;
    private string email = "victim@example.com";
    private string hostHeader = "evil.com";
    private string result = "";
    private string generatedEmail = "";
    private string resultCssClass = "";

    protected override void OnInitialized()
    {
        vulnerability = VulnerabilityService.GetBySlug("password-reset-poisoning")
            ?? throw new InvalidOperationException($"Vulnerability not found: password-reset-poisoning");
    }

    private void SendReset()
    {
        result = "";
        generatedEmail = "";

        if (string.IsNullOrWhiteSpace(email))
        {
            result = "Please enter an email address";
            resultCssClass = "alert alert-warning";
            return;
        }

        var token = Guid.NewGuid().ToString("N").Substring(0, 16);
        var resetUrl = $"https://{hostHeader}/reset?token={token}";

        generatedEmail = $@"From: noreply@legitsite.com
To: {email}
Subject: Password Reset Request

Hello,

You have requested to reset your password.
Click the link below to reset your password:

{resetUrl}

This link will expire in 1 hour.

If you did not request this, please ignore this email.

Best regards,
LegitSite Security Team";

        bool isAttack = !hostHeader.Equals("legitsite.com", StringComparison.OrdinalIgnoreCase);
        
        if (isAttack)
        {
            resultCssClass = "alert alert-danger";
            result = $"PASSWORD RESET POISONING!\n\n" +
                     $"Generated Reset Link:\n{resetUrl}\n\n" +
                     "The reset link points to attacker's domain!\n" +
                     "When victim clicks, token goes to attacker.";
        }
        else
        {
            resultCssClass = "alert alert-success";
            result = $"Password reset email sent to {email}";
        }
    }

    private void ExecuteAttack(PredefinedAttack attack)
    {
        email = attack.GetInput2AsString();
        hostHeader = attack.GetInputAsString();
        SendReset();
    }
}
