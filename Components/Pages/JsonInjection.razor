@page "/vulnerabilities/json-injection"
@rendermode InteractiveServer
@using DotnetSecurityFailures.Services
@using DotnetSecurityFailures.Models
@inject VulnerabilityService VulnerabilityService

<PageTitle>JSON Injection - .NET Security</PageTitle>

<VulnerabilityLayout Slug="json-injection" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <h6>Create a user profile API response:</h6>
        
        <div class="mb-3">
            <label class="form-label">Username:</label>
            <input type="text" class="form-control" @bind="username" placeholder="john_doe" />
        </div>
        
        <div class="mb-3">
            <label class="form-label">Bio:</label>
            <textarea class="form-control" rows="2" @bind="bio" placeholder="I love programming"></textarea>
        </div>
        
        <button class="btn btn-primary" @onclick="GenerateJson">Generate JSON Response</button>

        @if (!string.IsNullOrEmpty(executedInput))
        {
            <div class="alert alert-info mt-3">
                <strong>Input Values:</strong>
                <pre class="mb-0 mt-2 small"><code>Username: @username
Bio: @bio</code></pre>
            </div>
        }

        @if (!string.IsNullOrEmpty(jsonResult))
        {
            <div class="alert alert-warning mt-3">
                <strong>Generated JSON:</strong>
                <pre class="mb-0 mt-2" style="max-height: 300px; overflow-y: auto; font-family: 'Courier New', monospace;">@jsonResult</pre>
            </div>
        }

        @if (!string.IsNullOrEmpty(attackAnalysis))
        {
            <div class="alert alert-danger mt-3">
                <strong>Attack Analysis:</strong>
                <pre class="mb-0 mt-2" style="white-space: pre-wrap;">@attackAnalysis</pre>
            </div>
        }

        <div class="alert alert-dark mt-3">
            <strong>Try these attacks:</strong>
            <ul class="mb-0">
                @foreach (var attack in vulnerability.PredefinedAttacks)
                {
                    <li>
                        <code style="cursor: pointer;" @onclick="@(() => SetInput(attack.GetInputAsString(), attack.GetInput2AsString()))">@attack.GetInputAsString()</code>
                        @attack.Label
                    </li>
                }
            </ul>
        </div>


    </DemoContent>

    <ExplanationContent>
        <p>
            JSON injection occurs when user input is concatenated into JSON strings without 
            proper escaping. Attackers can inject quotes and special characters to break out 
            of their intended field and add malicious JSON properties.
        </p>
        
        <h6 class="mt-3">How the attack works:</h6>
        <pre class="bg-light p-2 small"><code>Input username: admin", "role": "administrator

JSON becomes:
{
  "username": "admin", "role": "administrator",
  "bio": "...",
  "role": "user",
  "isAdmin": false
}

Result: Attacker injects admin role property!</code></pre>

        <h6 class="mt-3">Why this is dangerous:</h6>
        <pre class="bg-light p-2 small"><code>Input bio: test", "isAdmin": true, "x": "

JSON becomes:
{
  "username": "user",
  "bio": "test", "isAdmin": true, "x": "",
  "role": "user",
  "isAdmin": false
}

Result: Attacker gains admin privileges!</code></pre>
        
        <h6 class="mt-4">Real-world consequences:</h6>
        <ul>
            <li><strong>Privilege escalation</strong> - inject admin roles or permissions</li>
            <li><strong>Data manipulation</strong> - modify prices, balances, quotas</li>
            <li><strong>Authentication bypass</strong> - add authentication flags</li>
            <li><strong>Business logic bypass</strong> - modify discount codes, limits</li>
            <li><strong>API abuse</strong> - inject rate limits, premium features</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against JSON Injection:</h5>
        <ol>
            <li><strong>Don't concatenate JSON</strong> - avoid string interpolation for JSON building</li>
            <li><strong>Use System.Text.Json </strong> - built-in serialization with automatic escaping</li>
            <li><strong>use strongly-typed objects</strong> - define classes/DTOs for your JSON structure</li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// CORRECT: Use System.Text.Json
using System.Text.Json;

public string GetUserProfile(string username, string bio)
{
    var userProfile = new
    {
        username = username,  // Automatically escaped
        bio = bio,            // Special characters handled
        role = "user",
        isAdmin = false
    };
    
    return JsonSerializer.Serialize(userProfile);
}

// Input: admin", "role": "administrator
// Serialized JSON:
// {"username":"admin\", \"role\": \"administrator","bio":"...","role":"user","isAdmin":false}
// Quotes are escaped - attack prevented!
""";
    private const string VulnerableCode = """
// DANGEROUS: String concatenation for JSON
public string GetUserProfile(string username, string bio)
{
    // Building JSON manually - VULNERABLE!
    var json = "{" + Environment.NewLine +
               $"  \"username\": \"{username}\"," + Environment.NewLine +
               $"  \"bio\": \"{bio}\"," + Environment.NewLine +
               "  \"role\": \"user\"," + Environment.NewLine +
               "  \"isAdmin\": false" + Environment.NewLine +
               "}";
    return json;
}
""";

    private Vulnerability? vulnerability;
    private string username = "";
    private string bio = "";
    private string? executedInput;
    private string? jsonResult;
    private string? attackAnalysis;

    protected override void OnInitialized()
    {
        vulnerability = VulnerabilityService.GetBySlug("json-injection")
            ?? throw new InvalidOperationException($"Vulnerability not found: json-injection");
    }

    private void GenerateJson()
    {
        ClearResults();

        if (string.IsNullOrWhiteSpace(username))
        {
            jsonResult = "Please enter a username";
            return;
        }

        // VULNERABLE: String concatenation for JSON - for demonstration
        var json = "{" + Environment.NewLine +
                   $"  \"username\": \"{username}\"," + Environment.NewLine +
                   $"  \"bio\": \"{bio}\"," + Environment.NewLine +
                   "  \"role\": \"user\"," + Environment.NewLine +
                   "  \"isAdmin\": false" + Environment.NewLine +
                   "}";

        executedInput = $"Username: {username}, Bio: {bio}";
        jsonResult = json;

        var predefinedAttack = vulnerability!.PredefinedAttacks
            .FirstOrDefault(a => a.GetInputAsString() == username && a.GetInput2AsString() == bio);
        
        if (predefinedAttack != null)
        {
            attackAnalysis = predefinedAttack.Description;
        }
        else
        {
            var input = (username + bio).ToLower();
            if (input.Contains("\"") && (input.Contains("role") || input.Contains("admin") || 
                input.Contains("balance") || input.Contains("quota") || input.Contains("apikey") || 
                input.Contains("discount") || input.Contains(",")))
            {
                attackAnalysis = "VULNERABILITY EXPLOITED!\n\n" +
                               "Custom injection detected!\n" +
                               "The input contains quotes and JSON syntax that may allow\n" +
                               "the attacker to inject additional properties into the JSON structure.\n\n" +
                               "This could lead to:\n" +
                               "- Unauthorized property injection\n" +
                               "- Business logic bypass\n" +
                               "- Data manipulation";
            }
        }
    }

    private void SetInput(string user, string bioText)
    {
        username = user;
        bio = bioText;
        ClearResults();
    }

    private void ClearResults()
    {
        executedInput = null;
        jsonResult = null;
        attackAnalysis = null;
    }
}
