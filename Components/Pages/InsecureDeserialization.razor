@page "/vulnerabilities/insecure-deserialization"
@rendermode InteractiveServer
@using System.Text
@using System.Runtime.Serialization.Formatters.Binary
@using System.Runtime.Serialization
@using System.Diagnostics
@using DotnetSecurityFailures.Services
@using DotnetSecurityFailures.Models
@inject VulnerabilityService VulnerabilityService

<PageTitle>Insecure Deserialization - .NET Security</PageTitle>

<VulnerabilityLayout Slug="insecure-deserialization" VulnerableCode="@VulnerableCode" SafeCode="@SafeCode">
    <DemoContent>
        <p>This demonstrates actual BinaryFormatter RCE vulnerability in the application.</p>

        <div class="mb-3">
            <label class="form-label">Serialized Data (Base64):</label>
            <textarea class="form-control font-monospace" rows="6" @bind="serializedData" 
                      placeholder="Paste Base64 encoded object data..."></textarea>
        </div>

        <button class="btn btn-primary w-100 mb-2" @onclick="DeserializeObject">
            Deserialize Object
        </button>

        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-sm btn-outline-secondary flex-fill" @onclick="LoadNormalObject">
                Normal User Object
            </button>
            <button class="btn btn-sm btn-outline-danger flex-fill" @onclick="LoadMaliciousPayload">
                Malicious Payload (RCE)
            </button>
        </div>

        @if (!string.IsNullOrEmpty(responseData))
        {
            <div class="@responseCssClass">
                <strong>@responseTitle</strong>
                <pre class="mb-0 mt-2 small" style="white-space: pre-wrap;">@responseData</pre>
            </div>
        }
    </DemoContent>

    <ExplanationContent>
        <p>
            <code>BinaryFormatter</code> is inherently insecure and can execute arbitrary code during deserialization.
            Microsoft has deprecated it and removed it from .NET 9+.
        </p>

        <h6 class="mt-3">How the attack works:</h6>
        <pre class="bg-light p-2 small"><code>1. Attacker crafts malicious serialized payload using ISerializable
2. Payload contains code in deserialization constructor
3. BinaryFormatter.Deserialize() executes the malicious code
4. Can run system commands, access files, install backdoors

Result: Complete server takeover!</code></pre>

        <h6 class="mt-4">Why BinaryFormatter is dangerous:</h6>
        <ul>
            <li><strong>Code Execution:</strong> Calls constructors, setters, handlers automatically</li>
            <li><strong>Type Confusion:</strong> Can instantiate any type in loaded assemblies</li>
            <li><strong>Gadget Chains:</strong> Attackers chain .NET classes to achieve RCE</li>
            <li><strong>No Validation:</strong> Blindly trusts serialized type information</li>
        </ul>

        <h6 class="mt-4">Consequences:</h6>
        <ul>
            <li><strong>Remote Code Execution:</strong> Complete server takeover</li>
            <li><strong>Data Theft:</strong> Access to databases and files</li>
            <li><strong>Lateral Movement:</strong> Attack internal systems</li>
            <li><strong>Persistence:</strong> Install malware and backdoors</li>
        </ul>
    </ExplanationContent>    <PreventionContent>
        <h5>Protection Against Insecure Deserialization:</h5>
        <ol>
            <li><strong>Don't Use BinaryFormatter:</strong> Deprecated (SYSLIB0011), removed from .NET 9+</li>
            <li><strong>Use Safe Serializers:</strong> (such as System.Text.Json) </li>
        </ol>
    </PreventionContent>
</VulnerabilityLayout>

@code {
    private const string SafeCode = """
// CORRECT: Use System.Text.Json

using System.Text.Json;

// Serialize to JSON
public void SaveSession(HttpContext context, UserSession session)
{
    var json = JsonSerializer.Serialize(session);
    
    context.Response.Cookies.Append("session", json,
        new CookieOptions
        {
            HttpOnly = true,
            Secure = true,
            SameSite = SameSiteMode.Strict,
            MaxAge = TimeSpan.FromHours(1)
        });
}

// Deserialize from JSON
public UserSession? LoadSession(HttpContext context)
{
    var json = context.Request.Cookies["session"];
    if (string.IsNullOrEmpty(json))
        return null;
    
    try
    {
        // Safe: Only deserializes to specific type
        return JsonSerializer.Deserialize<UserSession>(json);
    }
    catch (JsonException)
    {
        return null;
    }
}
""";
    private const string VulnerableCode = """
// DANGEROUS: BinaryFormatter = RCE vulnerability

#pragma warning disable SYSLIB0011
using System.Runtime.Serialization.Formatters.Binary;

public UserSession LoadSession(HttpContext context)
{
    var data = context.Request.Cookies["session"];
    if (string.IsNullOrEmpty(data))
        return null;

    var bytes = Convert.FromBase64String(data);
    var formatter = new BinaryFormatter();
    
    using var ms = new MemoryStream(bytes);
    
    // VULNERABLE: Attacker controls this data!
    // Can execute arbitrary code here
    return (UserSession)formatter.Deserialize(ms);
}
""";

    private Vulnerability? vulnerability;
    private string serializedData = "";
    private string responseData = "";
    private string responseTitle = "";
    private string responseCssClass = "";

    protected override void OnInitialized()
    {
        vulnerability = VulnerabilityService.GetBySlug("insecure-deserialization")
            ?? throw new InvalidOperationException($"Vulnerability not found: insecure-deserialization");
    }

#pragma warning disable SYSLIB0011
    private void DeserializeObject()
    {
        responseData = "";
        responseTitle = "";

        if (string.IsNullOrWhiteSpace(serializedData))
        {
            responseCssClass = "alert alert-warning";
            responseTitle = "Validation Error";
            responseData = "Please enter serialized data";
            return;
        }

        try
        {
            var bytes = Convert.FromBase64String(serializedData);
            var formatter = new BinaryFormatter();
            
            using var ms = new MemoryStream(bytes);
            var obj = formatter.Deserialize(ms);
            
            if (obj is MaliciousPayload)
            {
                responseCssClass = "alert alert-danger";
                responseTitle = "REMOTE CODE EXECUTION VULNERABILITY!";
                responseData = "Malicious payload deserialized!\n\n" +
                               "Calculator should now be running on the server.\n\n" +
                               "This demonstrates the critical vulnerability:\n" +
                               "- Code executed during deserialization\n" +
                               "- Attacker controls what code runs\n" +
                               "- Complete server compromise possible\n\n" +
                               "In a real attack, this could:\n" +
                               "- Install ransomware/backdoors\n" +
                               "- Steal database credentials\n" +
                               "- Exfiltrate sensitive data\n" +
                               "- Pivot to internal systems\n" +
                               "- Create persistent access";
            }
            else if (obj is UserData user)
            {
                responseCssClass = "alert alert-success";
                responseTitle = "Object Deserialized";
                responseData = $"User object deserialized successfully:\n\n" +
                               $"Username: {user.Username}\n" +
                               $"Email: {user.Email}\n" +
                               $"IsAdmin: {user.IsAdmin}\n\n" +
                               $"WARNING: Even 'safe' objects are dangerous!\n" +
                               $"Attackers can:\n" +
                               $"- Modify IsAdmin to true\n" +
                               $"- Change Username to admin\n" +
                               $"- Inject malicious type metadata\n\n" +
                               $"BinaryFormatter cannot be secured!";
            }
            else
            {
                responseCssClass = "alert alert-info";
                responseTitle = "Object Deserialized";
                responseData = $"Type: {obj?.GetType().Name ?? "null"}\n\n" +
                               $"BinaryFormatter will deserialize ANY type,\n" +
                               $"making it impossible to secure against attacks.";
            }
        }
        catch (Exception ex)
        {
            responseCssClass = "alert alert-warning";
            responseTitle = "Deserialization Error";
            responseData = $"{ex.Message}\n\n{ex.GetType().Name}";
        }
    }

    private void LoadNormalObject()
    {
        try
        {
            var user = new UserData 
            { 
                Username = "john.doe", 
                Email = "john@example.com", 
                IsAdmin = false 
            };
            
            var formatter = new BinaryFormatter();
            using var ms = new MemoryStream();
            formatter.Serialize(ms, user);
            
            serializedData = Convert.ToBase64String(ms.ToArray());
            responseData = "";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            responseCssClass = "alert alert-warning";
            responseTitle = "Error";
            responseData = $"Failed to create payload: {ex.Message}";
        }
    }

    private void LoadMaliciousPayload()
    {
        try
        {
            var payload = new MaliciousPayload();
            var formatter = new BinaryFormatter();
            using var ms = new MemoryStream();
            formatter.Serialize(ms, payload);
            
            serializedData = Convert.ToBase64String(ms.ToArray());
            
            responseCssClass = "alert alert-warning";
            responseTitle = "Malicious Payload Loaded";
            responseData = "REAL BinaryFormatter exploit loaded!\n\n" +
                           "Click 'Deserialize Object' to trigger RCE.\n\n" +
                           "The calculator will launch through the\n" +
                           "deserialization constructor.\n\n" +
                           "This is a working demonstration of CVE-style\n" +
                           "BinaryFormatter vulnerability.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            responseCssClass = "alert alert-warning";
            responseTitle = "Error";
            responseData = $"Failed to create payload: {ex.Message}";
        }
    }
#pragma warning restore SYSLIB0011

    [Serializable]
    public class UserData
    {
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public bool IsAdmin { get; set; }
    }

    //In reality this class is not required. An attacker can use a chain of standard classes to start any process using BinaryFormatter. For additonal information, refer to https://github.com/pwntester/ysoserial.net
    [Serializable]
    public class MaliciousPayload : ISerializable
    {
        public MaliciousPayload() { }

        protected MaliciousPayload(SerializationInfo info, StreamingContext context)
        {
            try
            {
                if (OperatingSystem.IsWindows())
                {
                    Process.Start(new ProcessStartInfo
                    {
                        FileName = "calc.exe",
                        UseShellExecute = true
                    });
                }
                else if (OperatingSystem.IsMacOS())
                {
                    Process.Start(new ProcessStartInfo
                    {
                        FileName = "open",
                        Arguments = "-a Calculator",
                        UseShellExecute = true
                    });
                }
                else
                {
                    try
                    {
                        Process.Start(new ProcessStartInfo
                        {
                            FileName = "gnome-calculator",
                            UseShellExecute = true
                        });
                    }
                    catch
                    {
                        Process.Start(new ProcessStartInfo
                        {
                            FileName = "kcalc",
                            UseShellExecute = true
                        });
                    }
                }
            }
            catch
            {
                // Silently fail
            }
        }

        public void GetObjectData(SerializationInfo info, StreamingContext context) { }
    }
}
